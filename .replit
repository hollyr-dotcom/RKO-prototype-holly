modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
 
[workflows]
runButton = "Project"
 
[[workflows.workflow]] 
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY = "pk_dev_placeholder"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "PORT=5000 HOSTNAME=0.0.0.0 node .next/standalone/server.js"]
build = ["sh", "-c", "npm run build && cp -r public .next/standalone/public && cp -r .next/static .next/standalone/.next/static"]
