# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Get your API key from https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Get your public key from https://liveblocks.io/dashboard/apikeys
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_dev_your-key-here

# Firebase Client (public, safe in frontend)
# Get these from Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=rko-project-2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=rko-project-2026
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=rko-project-2026.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
NEXT_PUBLIC_FIREBASE_APP_ID=...

# Firebase Admin (server-side only, keep secret)
# Get these from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_ADMIN_PROJECT_ID=rko-project-2026
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-...@rko-project-2026.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
