# ============================================================================
# REQUIRED FOR ALL DEVELOPMENT
# ============================================================================

# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Get your API key from https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Liveblocks — get keys from https://liveblocks.io/dashboard/apikeys
LIVEBLOCKS_SECRET_KEY=sk_dev_your-key-here
# DEPRECATED: Public key no longer needed (replaced by ID token auth)
# NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_dev_your-key-here

# Supabase — get these from your Supabase project settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# OPTIONAL: Auth.js Authentication (for production-like auth testing)
# ============================================================================
#
# NOTE: These are OPTIONAL for local development!
#
# If you omit these variables, the app will bypass authentication entirely
# and create a mock user (uid: 'local', email: 'dev@local').
#
# This lets you develop without any auth setup or SSO configuration.
# Only add these if you need to test actual authentication flows locally.
#
# ============================================================================

# Auth.js secret — generate with: openssl rand -base64 32
# AUTH_SECRET=your-generated-secret

# Google OAuth credentials from Google Cloud Console
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# Set to "true" to enable auth gate on the client
# NEXT_PUBLIC_AUTH_CONFIGURED=true
